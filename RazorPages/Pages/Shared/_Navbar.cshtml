@using Helpers.Constants

<!-- Navbar Start -->
<div class="container-fluid p-0 nav-bar">
    <nav class="navbar navbar-expand-lg bg-none navbar-dark py-3">
        <a href="index.html" class="navbar-brand px-lg-4 m-0">
            <h1 class="m-0 display-4 text-uppercase text-white">KOPPEE</h1>
        </a>
        <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
            <div class="navbar-nav ml-auto p-4">
                <a class="nav-item nav-link"
                       asp-page="Index">
                    @PageName.Home
                </a>
                <a href="about.html" class="nav-item nav-link">About</a>
                <a href="service.html" class="nav-item nav-link">Service</a>
                <a class="nav-item nav-link"
                       asp-page="@RouteName.Product/Index">
                    @PageName.Product
                </a>
                <div class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">Pages</a>
                    <div class="dropdown-menu text-capitalize">
                        <a href="reservation.html" class="dropdown-item">Reservation</a>
                        <a href="testimonial.html" class="dropdown-item">Testimonial</a>
                    </div>
                </div>
                <a href="contact.html" class="nav-item nav-link">Contact</a>
                @if (string.IsNullOrEmpty(Context.Session.GetString("JwtToken")))
                {
                    <a asp-page="/Account/Register" class="btn btn-outline-light font-weight-bold ml-3">
                        <i class="fa fa-user-plus mr-1"></i>Đăng ký
                    </a>
                    <a asp-page="/Account/Login" class="btn btn-primary font-weight-bold ml-2">
                        <i class="fa fa-sign-in mr-1"></i>Đăng nhập
                    </a>
                }
                else
                {
                    <div class="nav-item dropdown ml-3">
                        <a href="#" class="btn btn-primary font-weight-bold dropdown-toggle" data-toggle="dropdown">
                            <i class="fa fa-user-circle mr-1"></i>@Context.Session.GetString("Username")
                        </a>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" asp-page="/Account/Profile">
                                <i class="fa fa-id-card mr-2"></i>Trang cá nhân
                            </a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item text-danger" asp-page="/Account/Logout">
                                <i class="fa fa-sign-out mr-2"></i>Đăng xuất
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </nav>
</div>
<!-- Navbar End -->