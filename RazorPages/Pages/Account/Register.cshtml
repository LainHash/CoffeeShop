@page
@model RazorPages.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = "_AuthLayout";
}

<div class="auth-card" style="max-width: 520px;">
    <div class="auth-logo">
        <i class="fa fa-coffee"></i>
        <h4>Coffee Shop</h4>
    </div>
    <h2 class="auth-title">Tạo tài khoản</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
            <i class="fa fa-exclamation-circle"></i>
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <form method="post">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Input.FullName" class="form-label">Họ và tên</label>
                <input asp-for="Input.FullName" class="form-control" placeholder="Nguyễn Văn A" />
                <span asp-validation-for="Input.FullName" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Input.Username" class="form-label">Username</label>
                <input asp-for="Input.Username" class="form-control" placeholder="nguyenvana" autocomplete="username" />
                <span asp-validation-for="Input.Username" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label">Email</label>
            <input asp-for="Input.Email" class="form-control" placeholder="example@email.com" autocomplete="email" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Phone" class="form-label">Số điện thoại</label>
            <input asp-for="Input.Phone" class="form-control" placeholder="0912345678" autocomplete="tel" />
            <span asp-validation-for="Input.Phone" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Password" class="form-label">Mật khẩu</label>
            <div class="input-group">
                <input asp-for="Input.Password" type="password" id="passwordInput"
                       class="form-control" placeholder="Tối thiểu 6 ký tự, 1 hoa, 1 số"
                       autocomplete="new-password" />
                <button type="button" class="btn btn-outline-secondary" id="togglePassword"
                        style="border-color: rgba(255,255,255,0.2); color: #aaa; background: rgba(255,255,255,0.05);">
                    <i class="fa fa-eye" id="eyeIcon"></i>
                </button>
            </div>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Input.ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
            <input asp-for="Input.ConfirmPassword" type="password" id="confirmInput"
                   class="form-control" placeholder="Nhập lại mật khẩu"
                   autocomplete="new-password" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-auth">
            <i class="fa fa-user-plus me-2"></i>Tạo tài khoản
        </button>
    </form>

    <div class="auth-footer mt-3">
        Đã có tài khoản? <a asp-page="/Account/Login">Đăng nhập</a>
    </div>
    <div class="auth-footer mt-1">
        <a asp-page="/Index" class="text-muted">
            <i class="fa fa-arrow-left me-1"></i>Về trang chủ
        </a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('togglePassword').addEventListener('click', function () {
            const input = document.getElementById('passwordInput');
            const icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        });
    </script>
}
